{
  "name": "playwrong",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "dependencies": {
    "@playwrong/protocol": "workspace:*",
    "@playwrong/plugin-sdk": "workspace:*",
    "@playwrong/server": "workspace:*"
  },
  "scripts": {
    "plugins:generate": "bun scripts/generate-managed-plugins.ts",
    "build:extension": "bun run --cwd apps/extension build",
    "cli": "bun apps/cli/src/index.ts",
    "cli:serve": "bun apps/cli/src/index.ts serve --host 127.0.0.1 --port 7878",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bun test tests/e2e",
    "test:e2e:browser-google": "bun tests/e2e/browser-google-flow.ts",
    "test:e2e:browser-google:real": "PLAYWRONG_E2E_TARGET=real-google bun tests/e2e/browser-google-flow.ts",
    "test:e2e:capability-10-sites": "bun tests/e2e/browser-capability-10-sites.ts",
    "test:e2e:codex-google": "bun tests/e2e/codex-google-cli-flow.ts",
    "test:e2e:codex-google:real": "PLAYWRONG_E2E_TARGET=real-google bun tests/e2e/codex-google-cli-flow.ts"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "bun-types": "^1.2.22",
    "playwright": "^1.58.2",
    "typescript": "^5.6.3"
  }
}
